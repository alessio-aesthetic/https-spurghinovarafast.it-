---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import { business } from '~/data/spurghi';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: business.name,
  url: business.url,
  telephone: business.phoneHref,
  email: business.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Massaia, 2',
    postalCode: '28100',
    addressLocality: 'Novara',
    addressRegion: 'NO',
    addressCountry: 'IT',
  },
  areaServed: ['Novara', 'Trecate', 'Galliate', 'Borgomanero', 'Cameri', 'Cerano'],
  openingHours: 'Mo-Su 00:00-23:59',
};
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <a
      href={`tel:${business.phoneHref}`}
      class="md:hidden fixed bottom-4 left-4 right-4 z-50 rounded-full bg-blue-600 px-5 py-4 text-center text-base font-bold text-white shadow-2xl shadow-blue-600/30"
    >
      Chiama ora {business.phone}
    </a>

    <BasicScripts />
  </body>
</html>
